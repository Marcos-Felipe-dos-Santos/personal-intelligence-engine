# PIE — Personal Intelligence Engine
# Copy this file to .env and adjust values as needed.
# Keep real .env files out of Git. This example contains no secrets.

# Path to the SQLite database file (relative to project root)
PIE_DATABASE_PATH=pie.db

# Directory for generated Markdown notes
PIE_NOTES_DIR=notes

# Directory for generated reports
PIE_REPORTS_DIR=reports

# Log level: DEBUG, INFO, WARNING, ERROR
PIE_LOG_LEVEL=INFO

# Optional extraction backend.
# fake is deterministic and remains the default. ollama is experimental and local-only.
PIE_EXTRACTOR_BACKEND=fake

# Optional Ollama settings used only when PIE_EXTRACTOR_BACKEND=ollama.
PIE_OLLAMA_BASE_URL=http://localhost:11434
PIE_OLLAMA_MODEL=
PIE_LLM_TIMEOUT_SECONDS=30
PIE_LLM_MAX_RETRIES=2
PIE_LLM_RETRY_BACKOFF_SECONDS=1
